{
  "name": "mahadev-enterprises-erp",
  "version": "1.0.0",
  "description": "Mahadev Enterprises ERP - Inventory, Billing, GST, AI",
  "author": "Mahadev Enterprises",
  "main": "electron/main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "concurrently \"node server.js\" \"cd client && npx vite\"",
    "build-client": "cd client && npx vite build",
    "setup": "npm install && cd client && npm install && npm run build",
    "electron:dev": "concurrently \"node server.js\" \"wait-on http://127.0.0.1:3000/api/health && electron .\"",
    "electron:build": "npm run build-client && electron-builder --win",
    "electron:build-portable": "npm run build-client && electron-builder --win portable",
    "electron:publish": "npm run build-client && electron-builder --win --publish always",
    "electron:rebuild": "electron-builder install-app-deps",
    "node:rebuild": "npm rebuild sharp"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "bwip-js": "^4.5.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "electron-updater": "^6.8.9",
    "express": "^4.21.0",
    "groq-sdk": "^0.8.0",
    "multer": "^1.4.5-lts.1",
    "pdfkit": "^0.15.0",
    "sharp": "^0.33.5",
    "sql.js": "^1.14.1",
    "uuid": "^10.0.0"
  },
  "optionalDependencies": {
    "serialport": "^12.0.0",
    "usb-detection": "^4.15.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.mahadev.erp",
    "productName": "Mahadev Enterprises ERP",
    "copyright": "Copyright 2026 Mahadev Enterprises",
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "aryaanchavan1-commits",
        "repo": "mahadev_enterprises_ai_erp"
      }
    ],
    "files": [
      "db.js",
      "server.js",
      "routes/**/*",
      "electron/**/*",
      "client/dist/**/*",
      "data/**/*",
      "node_modules/adm-zip/**",
      "node_modules/bwip-js/**",
      "node_modules/cors/**",
      "node_modules/express/**",
      "node_modules/pdfkit/**",
      "node_modules/sql.js/**",
      "node_modules/multer/**",
      "node_modules/groq-sdk/**",
      "node_modules/electron-updater/**",
      "node_modules/accepts/**",
      "node_modules/array-flatten/**",
      "node_modules/body-parser/**",
      "node_modules/bytes/**",
      "node_modules/call-bind/**",
      "node_modules/content-disposition/**",
      "node_modules/content-type/**",
      "node_modules/cookie/**",
      "node_modules/cookie-signature/**",
      "node_modules/debug/**",
      "node_modules/depd/**",
      "node_modules/destroy/**",
      "node_modules/ee-first/**",
      "node_modules/encodeurl/**",
      "node_modules/escape-html/**",
      "node_modules/etag/**",
      "node_modules/finalhandler/**",
      "node_modules/forwarded/**",
      "node_modules/fresh/**",
      "node_modules/function-bind/**",
      "node_modules/get-intrinsic/**",
      "node_modules/has-symbols/**",
      "node_modules/hasown/**",
      "node_modules/http-errors/**",
      "node_modules/iconv-lite/**",
      "node_modules/inherits/**",
      "node_modules/ipaddr.js/**",
      "node_modules/media-typer/**",
      "node_modules/merge-descriptors/**",
      "node_modules/methods/**",
      "node_modules/mime/**",
      "node_modules/mime-db/**",
      "node_modules/mime-types/**",
      "node_modules/ms/**",
      "node_modules/negotiator/**",
      "node_modules/object-assign/**",
      "node_modules/object-inspect/**",
      "node_modules/on-finished/**",
      "node_modules/parseurl/**",
      "node_modules/path-to-regexp/**",
      "node_modules/qs/**",
      "node_modules/range-parser/**",
      "node_modules/raw-body/**",
      "node_modules/safe-buffer/**",
      "node_modules/safer-buffer/**",
      "node_modules/send/**",
      "node_modules/serve-static/**",
      "node_modules/setprototypeof/**",
      "node_modules/side-channel/**",
      "node_modules/statuses/**",
      "node_modules/toidentifier/**",
      "node_modules/type-is/**",
      "node_modules/unpipe/**",
      "node_modules/utils-merge/**",
      "node_modules/vary/**",
      "node_modules/buffer-from/**",
      "node_modules/pdfkit/**",
      "node_modules/linebreak/**",
      "node_modules/fontkit/**",
      "node_modules/png-js/**",
      "node_modules/crypto-js/**",
      "node_modules/brotli/**",
      "node_modules/dfa/**",
      "node_modules/restructure/**",
      "node_modules/tiny-inflate/**",
      "node_modules/unicode-properties/**",
      "node_modules/unicode-trie/**",
      "node_modules/base64-js/**",
      "node_modules/@types/**",
      "node_modules/dotenv/**",
      "node_modules/uuid/**",
      "node_modules/builder-util-runtime/**",
      "node_modules/lazy-val/**",
      "node_modules/js-yaml/**",
      "node_modules/semver/**",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "client/public/logo.ico"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Mahadev Enterprises ERP",
      "installerIcon": "client/public/logo.ico",
      "uninstallerIcon": "client/public/logo.ico"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/sharp/**"
    ],
    "npmRebuild": false,
    "includeSubNodeModules": true
  }
}
